@media (max-width: 976px) {

	.mobile{
		display: block;
	}
	.mobile-ib{
		display: inline-block;
	}
	.mobile-i{
		display: inline;
	}
	.desktop, .desktop-i,.desktop-ib{
		display: none;
	}
	.ui.overlay.sidebar{
		overflow: hidden!important;
	}
	#menu-hlavni-menu{
    margin: 14px 0 14px 0;
		width: 200%;
		height: 100%;
		overflow: auto;
		position: absolute;
		top: 0;
		transition: left 0.3s;
		will-change: left;
		left: 0;
		font-size: 20px;

		display: flex;
    flex-wrap: wrap;
    flex-direction: column;
    justify-content: center;
    align-items: stretch;

	}
	#menu-hlavni-menu a{
		margin: 0 23px 0 40px;
		padding: 0;
	}

	#menu-hlavni-menu > li.menu-item-has-children  > a:after{
    content: ">";
    display: inline-block;
    float: right;
	}
	#menu-hlavni-menu > li.menu-item-has-children > ul > div:before{
    content: "<";
    display: inline-block;
    margin-right: 10px;
	} 
	#menu-hlavni-menu > li{
		width: 50%;
	}
	#menu-hlavni-menu > li > ul.sub-menu {
    position: absolute;
    top: 0;
    left: 50%;
		flex-direction: column;
    justify-content: center;
    flex-wrap: wrap;
    top: 0;
    bottom: 0;
    width: 50%;
	} 
	#menu-hlavni-menu > li > ul.sub-menu{
		display: none;
	}
	#menu-hlavni-menu > li.open > ul.sub-menu{
		display: flex!important;
	}

	#menu-hlavni-menu.subMenuOpen{
		left: -100%;
	}
	.sidebar li.menu-item-has-children div {
    color: #c89040;
    border-bottom: 1px solid #3f4553;
		margin: 0 40px 0 23px;
	}
    
