    padding: 5px;
    text-overflow: ellipsis;
    display: inline-block;
    position: relative;
    z-index: 1;
    left: 0px;
    top: 0px;
    /* right: 12px; */
}

#searchInput {
    margin: 0 10px 5px 0;
    border: 1px solid #dedede;
    border-radius: 2px 0 0 2px;
    box-sizing: border-box;
    -moz-box-sizing: border-box;
    height: 32px;
    outline: none;
    background-color: #fff;
    font-family: Roboto;
    font-size: 15px;
    font-weight: 300;
    padding: 0 11px 0 13px;
    text-overflow: ellipsis;
    width: 237px;
}

#searchInputWrapper label{
font-weight: 400;
    margin-right: 10px;
    font-size: 13px;
    line-height: 1em;
}

#searchInputWrapper label input{
	display: inline-block;
    vertical-align: bottom;
	margin-right: 5px;
	margin-left: 1px;
}

#searchInput:focus {
    border-color: #4d90fe;
}

#map_canvas{
	border: 1px solid #3a2203;
}

#map_canvas #searchInput{
	display: block;
}


div#message {
    display: none;
}
.noselect{
    vertical-align: middle!important;
    min-width: 80px;
     user-select: none;
    -webkit-user-select: none;
    -ms-user-select: none;
    -webkit-touch-callout: none;
    -o-user-select: none;
    -moz-user-select: none;
}

.page-template-page-generator-pribehu tr:first-child td {
    border-top: none!important;
}

.content .acf-field {
    padding: 0!important;
	margin-bottom: 15px!important;
}

.content h1{
    line-height: 1.1em;
}
.woocommerce form .form-row .input-checkbox {
    position: static;
}

.woocommerce ul.order_details li {
    margin-right: 1em;
    padding-right: 1em;
}


.woocommerce .cart-collaterals .cross-sells, .woocommerce-page .cart-collaterals .cross-sells{
	width: 100%;
}


ul.products.columns-3, ul.products.columns-4,
.cross-sells ul.products.columns-2 {
	display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 0;
}


.cross-sells ul.products.columns-2:before, .cross-sells ul.products.columns-2:before,
ul.products.columns-3:after, ul.products.columns-4:after,
ul.products.columns-3:after, ul.products.columns-4:after{
	display: none;
}

.cross-sells ul.products.columns-2 li.product {
	width: 30.75%;
}


@media (min-width: 976px) {

	
}
@media (max-width: 600px) {
	.woocommerce ul.products[class*=columns-] li.product, .woocommerce-page ul.products[class*=columns-] li.product{
		width: 100%!important;
	}
}


div#tab-description h2:first-child {
	display: none;
}
.product_meta, form.woocommerce-ordering, p.woocommerce-result-count {
	display: none;
}
li#tab-title-test_tab {
	display: none;
}




@media (min-width: 601px) {
	.woocommerce ul.products li.product, .woocommerce-page ul.products li.product {
			margin: 0 3.875% 2.992em 0!important;
			width: 30.75%!important;
	}
	.woocommerce ul.products li, .woocommerce-page ul.products li.last {
    margin-right: 0!important;
	}
	.cross-sells ul.products.columns-2 li{
		margin: 0 3.875% 2.992em 0!important;
	}
	.cross-sells ul.products.columns-2 li:nth-child(3n){
		margin-right: 0!important;
	}

	section.related.products ul.products li.product,
	section.related.products ul.products li.produc {
		margin: 0 3.875% 2.992em 0!important;
		width: 48.06%!important;
	}
	section.related.products ul.products li.last {
		margin: 0 3.875% 2.992em 0!important;
	}
	section.related.products ul.products li:nth-child(2n) {
		margin-right: 0!important;
	}

	.woocommerce ul.products li.product a.button {
    position: absolute;
    bottom: 0;
	}
	.woocommerce ul.products li.product, .woocommerce-page ul.products li.product {
    padding-bottom: 25px;
	}

}

@media (min-width: 768px) {
	section.related.products ul.products li.product,
	section.related.products ul.products li.produc {
		margin: 0 3.875% 2.992em 0!important;
		width: 22.09%!important;
	}
	section.related.products ul.products li.last {
    margin-right: 0!important;
	}
}


.woocommerce #respond input#submit.alt, .woocommerce a.button.alt, .woocommerce button.button.alt, .woocommerce input.button.alt {
    background-color: #4CAF50;
    color: #fff!important;
    -webkit-font-smoothing: antialiased;
}

.woocommerce #respond input#submit.alt:hover, .woocommerce a.button.alt:hover, .woocommerce button.button.alt:hover, .woocommerce input.button.alt:hover {
    background-color: #59bf4f;
    color: #fff!important;
}

.woocommerce div.product .woocommerce-tabs .panel{
    min-height: 20px;
    padding: 19px;
    margin-bottom: 20px;
    background-color: #f5f5f5;
    border: 1px solid #e3e3e3;
    border-radius: 0 0 4px;
    -webkit-box-shadow: inset 0 1px 1px rgba(0,0,0,0.05);
    box-shadow: inset 0 -1px 1px rgba(0,0,0,0.05);
    background-color: rgba(245, 245, 245, 0.31);
    border: 1px solid rgba(180, 122, 43, 0.35);
    margin-top: -1px;
        border-color: #845d31;
}

.woocommerce div.product .woocommerce-tabs ul.tabs{
    margin: 0;
}
.woocommerce div.product .woocommerce-tabs ul.tabs li {


}

.woocommerce div.product .woocommerce-tabs ul.tabs::before {
    border-bottom: 1px solid #845d31;
}

.woocommerce div.product .woocommerce-tabs ul.tabs li {
    border: 1px solid #845d31;
}
.woocommerce div.product .woocommerce-tabs ul.tabs li.active {
    background: #ddcda9;
    z-index: 2;
    border-bottom-color: #ddcda9;
    box-shadow: inset 0 1px 1px rgba(0,0,0,0.05);
}

.woocommerce div.product .woocommerce-tabs ul.tabs li::after, .woocommerce div.product .woocommerce-tabs ul.tabs li::before {
    border: 1px solid #845d31;
}

.woocommerce div.product .woocommerce-tabs ul.tabs li.active::before {
    box-shadow: 2px 2px 0 #ddcda9;
    border-width: 0 1px 1px 0;
}

.woocommerce div.product .woocommerce-tabs ul.tabs li.active::after {
    box-shadow: -2px 2px 0 #ddcda9;
    border-width: 0 0 1px 1px;
}

.woocommerce .quantity .qty {
    height: 37px;
    border-radius: 5px;
    border: none;
}

.woocommerce form .form-row input.input-text, .woocommerce form .form-row textarea{
    display: block;
    width: 100%;
    height: 34px;
    padding: 6px 12px;
    font-size: 14px;
    line-height: 1.42857143;
    color: #555;
    background-color: #fff;
    background-image: none;
    border: 1px solid #ccc;
    border-radius: 4px;
    -webkit-box-shadow: inset 0 1px 1px rgba(0,0,0,0.075);
    box-shadow: inset 0 1px 1px rgba(0,0,0,0.075);
    -webkit-transition: border-color ease-in-out .15s, -webkit-box-shadow ease-in-out .15s;
    -o-transition: border-color ease-in-out .15s, box-shadow ease-in-out .15s;
    transition: border-color ease-in-out .15s, box-shadow ease-in-out .15s;
    
    border: 1px solid #af4b04;
    border: 1px solid #845d31;
    background: #c6ad74;
    color: #382313;
}
.woocommerce form .form-row textarea{
    height: auto;
}

.woocommerce div.product .woocommerce-tabs ul.tabs li::before {
    left: -5px;
    border-bottom-right-radius: 4px;
    border-width: 0 1px 1px 0!important;
    box-shadow: 2px 2px 0 #ebe9eb;
}

.woocommerce div.product .woocommerce-tabs ul.tabs li::after {
    right: -5px;
    border-bottom-left-radius: 4px;
    border-width: 0 0 1px 1px!important;
    box-shadow: -2px 2px 0 #ebe9eb;
}

.cart_totals.calculated_shipping h2 {
    font-size: 1.2em;
}

.select2-container--default .select2-selection--single .select2-selection__rendered {
    color: #444;
