.uroven-1,
.uroven-2,
.uroven-3,
.uroven-4{
	display: none;
}
.show-uroven-1 .uroven-1{
	display: block;
}
.show-uroven-2 .uroven-1,
.show-uroven-2 .uroven-2{
	display: block;
}
.show-uroven-3 .uroven-1,
.show-uroven-3 .uroven-2,
.show-uroven-3 .uroven-3{
	display: block;
}
.show-uroven-4 .uroven-1,
.show-uroven-4 .uroven-2,
.show-uroven-4 .uroven-3,
.show-uroven-4 .uroven-4{
	display: block; 
}

#cff .cff-author-img, #cff-lightbox-wrapper .cff-author-img {
	background: url(https://www.dracihlidka.cz/wp-content/uploads/2020/11/Kopie-souboru-HI-RES-ICO_v2.png)!important;
	background-size: 100% 100%!important;
}

#cff .cff-author-img img{
	display: none!important;
}

div#mailpoet_form_1 {
	border: none;
	background: none;
}

.mailpoet_spacer {
    display: none !important;
}

.mailpoet_form_column {
    flex-basis: unset !important;
}
label.mailpoet-screen-reader-text {
    display: none;
}

#topLine input[type="text"], #topLine input[type="email"] {
	height: 25px!important;
	width: 240px!important;
	border: none;
	outline: none;
	display: inline-block;
	font-size: 12px!important;
	padding: 0 10px!important;
	color: #e2e3f3!important;
	background: none!important;
	position: absolute;
	top: 10px;
	border-radius: 5px 0 0 5px!important;
	left: 3px;
	line-height: 25px!important;
}


input.mailpoet_submit {
	font-size: 14px!important;
	font-weight: bold!important;
	font-family: tahoma, sans-serif!important;
	color: #c89040!important;
	text-shadow: 0px 0px 3px black;
	position: absolute!important;
	right: 3px!important;
	width: 115px!important;
	height: 30px!important;
	top: 5px;
	padding: 0!important;
}

input.mailpoet_submit:hover {
	color: white!important;
}
#mailpoet_form_1 p.mailpoet_validate_success {
	width: 100%;
	line-height: 1.3;
	background: black;
	border-radius: 80px;
	padding: 5px 10px;
	border: 1px solid #b07116;
}
#mailpoet_form_1 .mailpoet_message {
	position: absolute;
	top: 39px!important;
	left: 0;
	right: 0;
}

.woocommerce-tabs .woocommerce-notices-wrapper{
	display: none;
}
.forums{
	display: none;
}

.hidden-forums .forums{
	display: block;
}

.screen-reader-text{
	display: none;
}
.alignright{
	float: right;
	margin: 0 0 1em 1em;
}
.alignleft{
	float: left;
	margin: 0 1em 1em 0;
}

p.text-right{
    text-align: right;
}

body{
	background: #0b0b0b;
	font-family: georgia, serif;
	font-size: 15px;
	color: #3a2203;
}

#map_canvas p {
    margin-bottom: 0.5em;
}

header.main{
	padding-top: 44px;
	font-family: Open Sans, sans-serif;
	margin-bottom: -8px;
	max-width: 100%;
	overflow: visible;
	position: relative;
}

header.main a{
	text-decoration: none;
}

@media (max-width: 976px) {
	header.main{
		height: auto!important;
		max-width: 800px;
		margin: 0 auto;
		min-width: 320px;
		padding-top: 0;
	}
}

@media (min-width: 977px) {
	body{
		min-width: 977px;
	}
	header.main{
		min-width: 977px;
	}
    
	.webp header nav{
		background: url('images/menu_bg.webp');
        background-position: top center;
        background-repeat: no-repeat;
		min-height: 297px;
		min-height: 318px;
		width: 100%;
		z-index: 3;
		position: relative;
		overflow: visible;
	}
    
    .no-webp header nav{
		background: url('images/menu_bg.png');
        background-position: top center;
        background-repeat: no-repeat;
		min-height: 297px;
		min-height: 318px;
		width: 100%;
		z-index: 3;
		position: relative;
		overflow: visible;
	}

	header nav.navbar-fixed-top{
		position: fixed;
		top: -245px;
		z-index: 10;
		min-width: 977px;
	}


	header nav>ul{
		margin: 0;
		padding: 0;
		list-style-type: none;
		position: relative;
		top: 245px;
		width: 1016px;
		margin: 0 0 0 -508px;
		left: 50%;
	}
	header nav>ul>li{
		position: absolute;
		display: block;
		height: 66px;
	/*	background: url('images/menu.png') no-repeat;*/
		/* position: relative; */
	}
	header nav>ul>li>a{
		display: block;
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		transition: background-image 0.25s ease-out;
		color: #e96136;
		text-decoration: none;
		text-align: center;
		text-transform: uppercase;
		line-height: 67px;
		font-weight: 600;
		font-size: 14px;
		text-shadow: -1px -1px 1px rgb(0, 0, 0);
		z-index: 3;
	}
	header nav>ul>li>a:hover,header nav>ul>li>a:focus{
		color: #fff;
		outline: none;
	}
	.webp header nav>ul>li>a, header nav>ul>li a{
		background: url('images/menu_fix.webp');
        background-repeat: no-repeat;
	}
    
    .no-webp header nav>ul>li>a, header nav>ul>li a{
		background: url('images/menu_fix.png');
        background-repeat: no-repeat;
	}
    
    
	header nav>ul>li>a:hover
/*	, header nav>ul>li.current-menu-item a*/
	{
		color: #fff;
	}
	header nav>ul>li:nth-child(1n){
		width: 173px;
	}
	header nav>ul>li:first-child>a{
		padding: 0 0 0 34px;
		width: 173px;
		background-position: 0 0;
		background-position: 0 -66px;
	}
	header nav>ul>li:nth-child(1n) a:active
/*	, header nav>ul>li:nth-child(1n).current-menu-item a, header nav>ul>li:nth-child(1n).current-menu-ancestor a, header nav>ul>li:nth-child(1n).current-menu-parent a*/
	{
		background-position: 0 -66px;
		background-position: 0 0;
	}
	header nav>ul>li:nth-child(2n){
		left: 173px;
		width: 134px;
	}
	header nav>ul>li:nth-child(2n)>a{
		width: 134px;
		background-position: -173px 0;
		background-position: -173px -66px;
	}
	header nav>ul>li:nth-child(2n) a:active
/*	, header nav>ul>li:nth-child(2n).current-menu-item a, header nav>ul>li:nth-child(2n).current-menu-ancestor a, header nav>ul>li:nth-child(2n).current-menu-parent a*/
	{
		background-position: -173px -66px;
		background-position: -173px 0;
	}
	header nav>ul>li:nth-child(3n){
		left: 307px;
		width: 133px;
	}
	header nav>ul>li:nth-child(3n)>a{
		width: 133px;
		background-position: -307px 0;
		background-position: -307px -66px;
	}
	header nav>ul>li:nth-child(3n) a:active
/*	, header nav>ul>li:nth-child(3n).current-menu-item a, header nav>ul>li:nth-child(3n).current-menu-ancestor a, header nav>ul>li:nth-child(3n).current-menu-parent a*/
	{
		background-position: -307px -66px;
		background-position: -307px 0;
	}
	header nav>ul>li:nth-child(4n){
		left: 440px;
		width: 134px;
	}
	header nav>ul>li:nth-child(4n)>a{
		width: 134px;
		background-position: -440px 0;
		background-position: -440px -66px;
	}
	header nav>ul>li:nth-child(4n) a:active
/*	, header nav>ul>li:nth-child(4n).current-menu-item a, header nav>ul>li:nth-child(4n).current-menu-ancestor a, header nav>ul>li:nth-child(4n).current-menu-parent a*/
	{
		background-position: -440px -66px;
		background-position: -440px 0;
	}
	header nav>ul>li:nth-child(5n){
		left: 574px;
		width: 134px;
	}
	header nav>ul>li:nth-child(5n)>a{
		width: 134px;
		background-position: -574px 0;
		background-position: -574px -66px;
	}
	header nav>ul>li:nth-child(5n) a:active
/*	, header nav>ul>li:nth-child(5n).current-menu-item a, header nav>ul>li:nth-child(5n).current-menu-ancestor a, header nav>ul>li:nth-child(5n).current-menu-parent a*/
	{
		background-position: -574px -66px;
		background-position: -574px 0;
	}
	header nav>ul>li:nth-child(6n){
		left: 708px;
		width: 134px;
	}
	header nav>ul>li:nth-child(6n)>a{
		width: 134px;
		background-position: -708px 0;
		background-position: -708px -66px;
	}
	header nav>ul>li:nth-child(6n) a:active
/*	, header nav>ul>li:nth-child(6n).current-menu-item a, header nav>ul>li:nth-child(6n).current-menu-ancestor a, header nav>ul>li:nth-child(6n).current-menu-parent a*/
	{
		background-position: -708px -66px;
		background-position: -708px 0;
	}
	header nav>ul>li:nth-child(7n){
		left: 842px;
		width: 174px;
	}
	header nav>ul>li:nth-child(7n)>a{
		width: 174px;
		background-position: -842px 0;
		background-position: -842px -66px;
	}
	header nav>ul>li:nth-child(7n)>a:active
/*	, header nav>ul>li:nth-child(7n).current-menu-item a, header nav>ul>li:nth-child(7n).current-menu-ancestor a, header nav>ul>li:nth-child(7n).current-menu-parent a*/
	{
		background-position: -842px -66px;
		background-position: -842px 0;
	}
	header nav>ul>li:nth-child(7n)>a{
		padding: 0 34px 0 0;
	}


	/* sub menu */

	header nav ul ul{
		display:none;
		position:absolute;
		top:100%;
		left:0;
		background: transparent;
		padding: 0px;
		width: 200px;
		margin: -9px 0 0 0;
		list-style: none;
		border-top: 1px solid #8b3123;
		border-bottom: 1px solid #82351b;
		z-index: 2;
		font-size: 14px;
		/* background: #000000; */
		border-radius: 0 0 5px 5px;
		box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.37);
		background: rgba(20, 20, 20, 0.9);
	}
	
	header nav>ul>li:first-child ul{
		left: 33px;
	}

	header nav>ul>li>ul>li:first-child{
		padding-top: 15px;
		 /*background: -moz-linear-gradient(top,  rgba(3,3,3,1) 7px,rgba(20,20,20,0.8) 10px);  /*FF3.6-15 */
		 /*background: -webkit-linear-gradient(top,  rgba(3,3,3,1) 7px,rgba(20,20,20,0.8) 10px); /* Chrome10-25,Safari5.1-6 */
		 /*background: linear-gradient(to bottom,  rgba(3,3,3,1) 7px,rgba(20,20,20,0.8) 10px); /* W3C, IE10+, FF16+, Chrome26+, Opera12+, Safari7+ */
	}
	header nav>ul>li>ul>li:last-child{
		padding-bottom: 6px;
	}
	header nav>ul>li>ul li:last-child{
		border-radius: 0 0 5px 5px;
	}
	header nav ul ul li{
		float:none;
		width:200px;
		position: relative;
		border-left: 1px solid #4a2e2a;
		border-right: 1px solid #4a2e2a;
	}

	header nav ul ul a{
		line-height:120%;
		padding:10px 15px;
		color: #a27e51;
		text-decoration: none;
		padding: 7px 18px;
		display: block;
		background: transparent;
	}

	header nav ul ul a:hover{
		color: #ecdcb1;
		text-decoration: underline;
	}

	header nav ul ul .current-menu-ancestor>a, header nav ul ul .current-menu-parent>a, header nav ul ul .current-menu-item>a{
		text-decoration:underline;
	}

	header nav ul ul li:hover>a{
		text-decoration: underline;
		background: rgba(0,0,0,0.8);
	}

	header nav ul ul ul{
		top: 9px;
		left: 100%;
		margin-left: 1px;
	}

	header nav ul li:hover > ul{
		display:block
	}

	header nav>ul>li>ul .menu-item-has-children>a{
		background-image: url(images/oa.png);
		background-repeat: no-repeat;
		background-position: 179px center!important;
	}
}

	header nav>ul>li:nth-child(8n), header nav>ul>li:nth-child(9n), header nav>ul>li:nth-child(10n){
		display: none;
	}

#topLine{
	height: 44px;
	position: absolute;
	top: 0;
	right: 0;
	left: 0;
	background-color: #0b0b0b;
	box-shadow: 0 1px 25px black;
}

#promo{
	text-align: center;
	margin-bottom: -256px;
}
#promo .item{
	height: 571px;
	height: 452px;
	
}

.webp #promo .desktop{
    background: url('images/promo_1.webp') top center no-repeat;
}

.no-webp #promo .desktop{
    background: url('images/promo_1.jpg') top center no-repeat;
}

.item.desktop.lazy {
	background-position: center;
	background-repeat: no-repeat;
	background-color: #0b0b0b;}
	
#search {
	width: 1016px;
	margin: 0 auto;
	position: relative;
	z-index: 3;
	left: 50%;
	margin-left: -508px;
}
#search-button{
	position: absolute;
	bottom: 80px;
	right: 62px;
	width: 38px;
	border: 0;
	background: transparent;
	height: 26px;
	outline: none;
}

@media (min-width: 977px) {
	#search-button:active{
		background: url('images/menu_bg.png') top left no-repeat;
		background-position:0 -320px;
	}
}
#search-input{
	position: absolute;
	bottom: 81px;
	right: 101px;
	width: 206px;
	border: 0;
	background: transparent;
	height: 26px;
	font-size: 12px;
	padding: 0 16px;
	color: #e2e3f3;
	outline: none;
}

.container{
	position: relative;
	margin: 0 auto;
	width: 906px;
	z-index: 2;
}
.container a:not(.btn){
	text-decoration: none;
	
	color: #3a2203;
}
.container a:not(.btn):active, .container a:not(.btn):hover {
    outline: 0;
	color: #000;
	text-decoration: none;
}

.content img{
	max-width: 100%;
	height: auto;
}
@media (min-width: 768px) {
	.content img.maw200{
		max-width: 200px;
	}	
}


.content p{
	margin: 0 0 1em 0;
}

.content .alert p{
	margin: 0;
}
.content .alert p + p{
		margin: 1em 0 0 0;
}

#promo img{
	max-width: 100%;height: auto;
}
@media (max-width: 976px) {
	#topLine{
		box-shadow: 0 4px 16px black;
		min-height: 44px;
		height: auto;
		position: relative;
		z-index: 10;
	}
	#topLine:after{
		clear: both;
		content: "";
		display: block;
	}
	#promo{
		margin-bottom: 0;
	}
	#promo .item{
		height: auto;
	}
	#search-button{
		bottom: 0;
		right: -3px;
		outline: none;
	}
	#search-input{
		right: 36px;
		bottom: 0;
		width: 164px;
		font-size: 11px;
		height: 29px;
	}
	.container{
		width: auto;
		max-width: 800px;
		z-index: 2;
		min-width: 320px;
	}
	.container img{
		max-width: 100%;
		display: block;
	}


}


/* TODO main */

.pergamen{
	min-height: 593px;
	background: url(images/pergamen.png) center top repeat-y;
	position: relative;
}
.pergamen:before{
	content: "";
	display: block;
	position: absolute;
	width: 100%;
	top: 0;
	height: 121px;
	background: url(images/pergamen_top-2.png) top center no-repeat;
}
.pergamen:after{
	content: "";
	display: block;
	position: absolute;
	width: 100%;
	bottom: 0;
	height: 126px;
	background: url(images/pergamen_bottom_2.png) bottom center no-repeat;
/*	background: url(images/pergamen_bottom.png) bottom center no-repeat;*/
}
.pergamen .container{
	padding: 20px 2px;
}
.pergamen .container .content{
	padding: 0 14px 127px 14px;
	padding: 0 20px 127px 20px;
	position: relative;
	font-size: 16px;
	line-height: 1.5em;
}
.pergamen .container .symbol{
	position: absolute;
	top: 0;
	left: 0;
	top: 20px;
}
.container header{
	padding-top: 1px;
	z-index: 2;
	position: relative;
	padding-left: 14px;
}
.pergamen .container header{
	min-height: 104px;
	line-height: normal;
	padding-bottom: 11px;
}
.container header h1{
	color: #3a2203;
	margin: 11px 0 0 0;
	font-size: 35px;
}

.container header h1>a, .container header h2>a{
	color: inherit!important;
	text-decoration: none!important;
}
.container header h2{
	color: #3a2203;
	margin: 15px 0 0 0px;
	font-size: 17px;
	font-weight: 400;
}
.container header .date{
	color: #3a2203;
	margin: 15px 0 0 0px;
	font-size: 17px;
	font-weight: 400;
}
.symbol + header h1 {
	padding: 0 0 0 104px;
}

.symbol + header h2 {
	padding: 0 0 0 140px;
}

@media (max-width: 976px) {
	.pergamen{
		background: #d2bb87;
		max-width: 800px;
		margin: 0 auto;
	}
	.pergamen:before{
		background: url(images/pergamen_top_mobile.png) top center repeat-x;
	}
	.pergamen:after{
		background: url(images/pergamen_bottom_mobile.png) bottom center repeat-x;
	}
	.pergamen .container .content{
		padding: 0 15px 50px;
	}
	.symbol + header h1{
		padding: 0 0 10px 0;	
	}
	.symbol + header h2{
		padding: 0;
		margin-top: 0;
	}
	.symbol + header {
    min-height: 73px!important;
		display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
		row-gap: 7px;
    column-gap: 30px;
		padding-right: 14px;
	}
}

article h2 + .date{
	margin: -1em 0 1em 0;
	font-weight: 700;
	font-style: italic;
}
.text-center {
	text-align: center;
}
.content .text-center .btn.btn-back{
	text-align: center;
	margin: 1em 0 -1em 0;
}

.btn-info,.btn-info:hover, .btn-info:focus , .btn-info:active {
    color: #ffffff;
    background-color: #71421e;
    border-color: #d2bb87;
}

.btn-warning {
    color: #fff;
    background-color: #b47b30;
    border-color: #9c611d;
	
	    background-color: #c79f4b;
    border-color: #dfc281;
}

.btn-warning:hover {
    color: #fff;
    background-color: #ec971f;
    border-color: #d58512;
    background-color: #b47b30;
    border-color: #9c611d;
}


footer{
	width: 977px;
	margin: 2px auto;
	background: #151515 url(images/footer.png) top center repeat-x;
	padding: 36px 72px;
	margin-bottom: 1em;
	position: relative;
	max-width: 100%;
}
footer .ikony{
	float: left;
	width: 126px;
}
footer .onas{
	float: left;
	margin-left: 44px;
	width: 185px;
}
footer .pravidla{
	float: left;
	width: 230px;
}
footer .kontakty{
	float: left;
	width: 243px;
}

footer small{
	display: block;
	clear: both;
	background: url('images/oddelovac_horozontal.png') top center no-repeat;
	text-align: center;
	color: #727272;
	font-size: 14px;
	padding: 30px 0 0 0;
	margin: 0 -17px;
}
footer small a{
	text-decoration: none;
	color: inherit;
	font-size: 17px;
	margin-left: 1em;
}

footer h5{
	font-size: 17px;
	letter-spacing: 2px;
	color: #727272;
	margin: 2px 0 28px 0;
}

.formular__ikony {
	display: flex;
	gap: 10px;
	margin-bottom: 10px;
	flex-wrap: wrap;
	flex-direction: row;
}
.formular__ikona{
	background: #c6ad74;
	cursor: pointer;
	border: 1px solid #845d31;
	border-radius: 5px;
	text-align: center;
	padding: 10px;
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	flex-grow: 2;
	width: 100px;
}

.formular__ikona:hover, .formular__ikona.active{
	background: #ab8a57;
}
.formular__ikona img {
	width: 80px;
	height: 80px;
}
.ikona__text {
	font-size: 104%;
	margin-top: 10px;
}
.formular__nadpis {
	max-width: 100%;
	margin: 1em 0;
	font-weight: 700;
	text-align: center;
	font-size: 150%;
}

@media (max-width: 976px) {
	footer{
		width: auto;
		max-width: 800px;
		min-width: 320px;
		margin-bottom: 0;
