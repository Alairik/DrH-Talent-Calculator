.faq-group .panel{
    border: 1px solid #845d31;
    background:#c6ad74;
    position: relative;
        padding: 0 10px;
    margin-bottom: 8px;
    border-radius: 0;
}

.faq-group .panel{
	transition: all 0.25s ease-out;
}
.faq-group .open{
	border: 1px solid #845d31;
	display: block;
	background: #c6ad74;
}
.faq-group .panel-heading:before{
    content: "";
    display: block;
    background: url(images/ico-nav-sidebar.svg) top no-repeat;
    width: 25px;
    height: 19px;
    position: absolute;
    top: 12px;
	top: 9px;
    left: 7px;
    -webkit-transform: rotate(180deg);
    -moz-transform: rotate(180deg);
    -o-transform: rotate(180deg);
    -ms-transform: rotate(180deg);
    transform: rotate(180deg);
    background-size: 75%;
	-webkit-transition: .2s;
    transition: .2s;
}

.faq-group .open .panel-heading:before{
	-webkit-transform: rotate(0);
    -moz-transform: rotate(0);
    -o-transform: rotate(0);
    -ms-transform: rotate(0);
    transform: rotate(0);
	top: 12px;
}

