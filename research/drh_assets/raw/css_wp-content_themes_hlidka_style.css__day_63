.woocommerce ::-moz-placeholder { /* Firefox 19+ */
  color: white;
}
.woocommerce :-ms-input-placeholder { /* IE 10+ */
  color: white;
}
.woocommerce :-moz-placeholder { /* Firefox 18- */
